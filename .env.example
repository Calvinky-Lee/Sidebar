# The Council — environment variables (names only; see specs/09-infra-and-keys.md)
# Copy to .env at the repo root (one file, loaded by both apps). NEVER commit real values.

GEMINI_API_KEY=               # Google AI Studio — required: intake, members, search grounding
ANTHROPIC_API_KEY=            # OPTIONAL — enables Claude models in the multi-model registry
OPENAI_API_KEY=               # OPTIONAL — enables GPT models in the multi-model registry
VOYAGE_API_KEY=               # Voyage AI — voyage-3 embeddings (MongoDB-owned)
MONGODB_URI=                  # Atlas SRV connection string — council-service + seed only
COUNCIL_SERVICE_URL=http://localhost:8787
COUNCIL_SERVICE_TOKEN=        # OPTIONAL — off by default locally
TAVILY_API_KEY=               # OPTIONAL — only if Google Search grounding unavailable
COST_CAP_USD=0.50             # per-session kill-switch (paid keys only)
DEMO_MODE=0                   # 1 = stream golden fixture instead of live deliberation
